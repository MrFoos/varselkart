# MET MetAlerts — ingen nøkkel, men User-Agent er obligatorisk
MET_USER_AGENT=varselkart/1.0 (https://varselkart.no)

# Statens vegvesen DATEX II (krever registrering på vegvesen.no/datex)
DATEX_USERNAME=
DATEX_PASSWORD=

# Avinor XML feed (prøv uten nøkkel først; fyll inn hvis 401)
AVINOR_API_KEY=

# ntfy backend-token (genereres via: ntfy user add --role=admin backend_publisher)
NTFY_TOKEN=
NTFY_BASE_URL=https://ntfy.varselkart.no

# Database
DATABASE_PATH=./varselkart.db

# Applikasjon
APP_ENV=development
APP_PORT=8000
